# === 数据库 ===
POSTGRES_USER=eval_user
POSTGRES_PASSWORD=<改成强密码>
POSTGRES_DB=eval_platform

# === 后端 ===
EVAL_DEBUG=false
# 填写实际访问地址，JSON 数组格式，如 ["http://192.168.1.100"]
EVAL_CORS_ORIGINS=["http://<服务器IP>"]
# 内网部署默认允许访问内网地址，如需禁止设为 false
# EVAL_ALLOW_PRIVATE_URLS=false

# === 端口（宿主机映射）===
FRONTEND_PORT=80

# === 前端 → 后端代理（通常不需要改）===
# 如果不用 docker-compose 启动，改为后端实际地址
BACKEND_HOST=backend
BACKEND_PORT=8000

# === 性能 ===
# UVICORN_WORKERS=2
